{
    "name": "nuxt-devtools-observatory",
    "version": "0.1.23",
    "description": "Nuxt DevTools: useFetch Dashboard, provide/inject Graph, Composable Tracker, Render Heatmap",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/victorlmneves/nuxt-devtools-observatory.git"
    },
    "homepage": "https://github.com/victorlmneves/nuxt-devtools-observatory#readme",
    "type": "module",
    "main": "./dist/module.mjs",
    "module": "./dist/module.mjs",
    "exports": {
        ".": {
            "types": "./dist/module.d.mts",
            "import": "./dist/module.mjs"
        },
        "./runtime/composable-registry": {
            "types": "./dist/runtime/composables/composable-registry.d.ts",
            "import": "./dist/runtime/composables/composable-registry.js"
        },
        "./runtime/provide-inject-registry": {
            "types": "./dist/runtime/composables/provide-inject-registry.d.ts",
            "import": "./dist/runtime/composables/provide-inject-registry.js"
        },
        "./runtime/fetch-registry": {
            "types": "./dist/runtime/composables/fetch-registry.d.ts",
            "import": "./dist/runtime/composables/fetch-registry.js"
        }
    },
    "files": [
        "dist",
        "client"
    ],
    "scripts": {
        "dev": "nuxi dev playground",
        "build:client": "vite build --config client/vite.config.ts",
        "build": "npm run build:client && nuxt-module-build build",
        "prepack": "npm run build",
        "lint": "eslint .",
        "format": "prettier --write '**/*.{ts,vue,js,json}' --ignore-path .prettierignore && stylelint '**/*.{css,vue}' --ignore-pattern '.nuxt/**' --ignore-pattern '.output/**' --ignore-pattern 'coverage/**' --ignore-pattern 'client/dist/**' --fix && eslint --fix '**/*.{ts,vue,js}' --ignore-pattern 'coverage/**' --ignore-pattern 'client/dist/**'",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:screenshots": "playwright test scripts/playwright/screenshot-trackers.spec.ts",
        "test:e2e": "playwright test scripts/playwright/playground-pages.spec.ts",
        "capture:screenshots": "node scripts/playwright/capture-observatory-screenshots.cjs"
    },
    "dependencies": {
        "@babel/generator": "^7.29.1",
        "@babel/parser": "^7.29.0",
        "@babel/traverse": "^7.29.0",
        "@babel/types": "^7.29.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@nuxt/eslint": "^1.13.0",
        "@nuxt/kit": "^3.0.0",
        "@nuxt/module-builder": "^1.0.2",
        "@nuxt/schema": "^3.0.0",
        "@pinia/nuxt": "^0.11.3",
        "@playwright/test": "^1.58.2",
        "@types/babel__generator": "^7.27.0",
        "@types/babel__traverse": "^7.28.0",
        "@types/node": "^25.5.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vitest/coverage-v8": "^4.1.0",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.5.0",
        "eslint-plugin-jsonc": "^2.21.0",
        "eslint-plugin-regexp": "^3.0.0",
        "eslint-plugin-vue": "^10.7.0",
        "globals": "^17.3.0",
        "happy-dom": "^20.8.4",
        "nuxt": "^3.0.0 || ^4.0.0",
        "pinia": "^3.0.4",
        "playwright": "^1.58.2",
        "postcss-html": "^1.8.1",
        "prettier": "^3.8.1",
        "stylelint": "^17.4.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.54.0",
        "unbuild": "^3.6.1",
        "vite": "^6.4.1",
        "vitest": "^4.1.0",
        "vue": "^3.5.30",
        "vue-eslint-parser": "^10.2.0"
    },
    "keywords": [
        "nuxt",
        "devtools",
        "vue",
        "performance",
        "debugging"
    ],
    "peerDependencies": {
        "@nuxt/kit": "^3.0.0 || ^4.0.0"
    }
}
