{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "lib": ["ESNext", "DOM"],
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@observatory/*": ["../src/*"],
            "@observatory-client/*": ["./src/*"],
            "@observatory-tests/*": ["../tests/*"],
            "*": ["../node_modules/*"]
        }
    },
    "include": ["**/*.ts", "**/*.vue"]
}
