{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "preserve",
        "lib": ["ESNext", "DOM"],
        "baseUrl": ".",
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "*": ["../node_modules/*"]
        }
    },
    "include": ["**/*.ts", "**/*.vue"]
}
